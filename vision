<script>
  let pendingIgnoreCard = null;

  function toggleMenu(el) {
    el.classList.toggle('open');
  }
  function setActive(el) {
    document.querySelectorAll('.sub-item').forEach(i => i.classList.remove('active'));
    el.classList.add('active');
  }

  function filterBy(type, card) {
    document.querySelectorAll('.summary-card').forEach(c => c.classList.remove('active-card'));
    card.classList.add('active-card');
    document.querySelectorAll('.task-card').forEach(tc => {
      if (type === 'all') {
        tc.style.display = 'flex';
      } else {
        tc.style.display = tc.dataset.type === type ? 'flex' : 'none';
      }
    });
  }

  function searchTasks(val) {
    const q = val.toLowerCase();
    document.querySelectorAll('.task-card').forEach(tc => {
      tc.style.display = tc.dataset.name && tc.dataset.name.toLowerCase().includes(q) ? 'flex' : 'none';
    });
  }

  function completeTask(btn) {
    const card = btn.closest('.task-card');
    btn.textContent = '✓ 완료됨';
    btn.style.background = '#d1fae5';
    btn.style.color = '#065f46';
    btn.disabled = true;
    card.style.opacity = '0.45';
    setTimeout(() => {
      card.style.maxHeight = '0';
      card.style.paddingTop = '0';
      card.style.paddingBottom = '0';
      card.style.marginBottom = '0';
      card.style.border = 'none';
      card.style.overflow = 'hidden';
    }, 500);
  }

  function openIgnoreModal(btn, name, loc) {
    pendingIgnoreCard = btn.closest('.task-card');
    document.getElementById('modal-product-name').textContent = name;
    document.getElementById('modal-product-loc').textContent = '📍 ' + loc;
    document.getElementById('ignoreModal').classList.add('show');
  }

  function closeModal() {
    document.getElementById('ignoreModal').classList.remove('show');
    pendingIgnoreCard = null;
  }

  function confirmIgnore() {
    if (pendingIgnoreCard) {
      pendingIgnoreCard.style.opacity = '0.3';
      setTimeout(() => {
        pendingIgnoreCard.style.maxHeight = '0';
        pendingIgnoreCard.style.paddingTop = '0';
        pendingIgnoreCard.style.paddingBottom = '0';
        pendingIgnoreCard.style.border = 'none';
        pendingIgnoreCard.style.overflow = 'hidden';
      }, 300);
    }
    closeModal();
  }

  // Close modal on overlay click
  document.getElementById('ignoreModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
</script>
